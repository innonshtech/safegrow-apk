# Application
NODE_ENV=development
APP_VERSION=1.0.0

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/safegrow

# Redis (Queues & Caching)
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=super-secret-key-123
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=super-secret-refresh-key-123
REFRESH_TOKEN_EXPIRES_IN=7d
OTP_EXPIRY_MINUTES=5

# AWS S3 (Storage)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET_NAME=safegrow-uploads

# Google & Firebase
GOOGLE_MAPS_API_KEY=your_google_maps_key
FCM_SERVER_KEY=your_fcm_key
ANDROID_PACKAGE_NAME=com.safegrow.app
IOS_BUNDLE_ID=com.safegrow.app

# Mobile Config
BACKGROUND_TRACKING_INTERVAL_MS=900000
MOCK_LOCATION_ALLOWED=false

# Emails
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=user
SMTP_PASS=pass
